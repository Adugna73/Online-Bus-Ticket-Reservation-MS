{
  "name": "online-bus-ticket-reservation-ms",
  "version": "0.1.0",
  "private": true,
  "jest": {},
  "vitest": {},
  "scripts": {
    "dev": "npm run web:dev",
    "dev:nodemon": "nodemon --watch app --watch components --ext ts,tsx --exec \"npm run web:dev\"",
    "web:dev": "cross-env NEXT_DISABLE_TURBO=1 next dev --port 3000",
    "web:build": "NEXT_DISABLE_TURBO=1 next build",
    "build": "NEXT_DISABLE_TURBO=1 next build",
    "start": "next start",
    "start:all": "concurrently \"npm run start\" \"npm run bot\"",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "guard:docs:fix": "node scripts/check-docs.mjs --fix",
    "guard:docs": "node scripts/check-docs.mjs",
    "git-hooks:install": "git config core.hooksPath .githooks || true",
    "seed:regions": "tsx scripts/seed-regions.ts",
    "check:region-zones": "tsx scripts/check-region-zones.ts",
    "import:staff": "tsx scripts/import-staff.ts",
    "seed:bus": "tsx scripts/seed-bus.ts",
    "seed:gap": "tsx scripts/seed-gap-features.ts",
    "seed:all": "tsx scripts/seed-bus.ts && tsx scripts/seed-gap-features.ts",
    "db:seed": "npm run seed:bus",
    "seed:deploy": "node scripts/run-seed.js && node scripts/post-seed-adjust.js",
    "docker:init": "bash scripts/docker-init.sh",
    "format:staff": "tsx scripts/format-staff.ts",
    "test:integration:prepare": "npx prisma generate --schema=prisma/test.schema.prisma && npx prisma db push --schema=prisma/test.schema.prisma",
    "test:integration": "cross-env DATABASE_URL=file:./tmp/test-db.sqlite npm run test:integration:prepare && npx vitest run tests/checklist.integration.spec.ts",
    "assign:hq-zones": "tsx scripts/assign-hq-managers-zones.ts",
    "auto-schedule:weekly": "tsx scripts/auto-schedule-weekly.ts"
  },
